# Токен от @BotFather (обязательно)

TELEGRAM_BOT_TOKEN=

# Docker compose: оставьте по умолчанию (встроенный searxng сервис).
# Локальный запуск без docker-compose: поставьте http://localhost:8080
SEARXNG_BASE_URL=http://searxng:8080

BOT_DATA_DIR=data

SEARCH_RESULTS_LIMIT=10
SEARCH_PAGES_MAX=2

DEEP_SEARCH_RESULTS_LIMIT=80
DEEP_SEARCH_PAGES_MAX=4
DEEP_ENRICHMENT_MAX_EVENTS=400
DEEP_ENRICHMENT_MAX_ROUNDS=8
DEEP_ENRICHMENT_BATCH_SIZE=30
DEEP_CATALOG_EXPANSION_MAX=150
DEEP_CATALOG_MAX_LINKS=18
PAGE_FETCH_TIMEOUT=25
PAGE_FETCH_CONCURRENCY=6
DEEP_SEARCH_MAX_ACTIVE_PER_USER=2

QUERY_SUFFIX=
LOG_LEVEL=INFO

# Общая БД с partnership-bot (Docker volume partnership-leads-data)
PARTNERSHIP_DATA_DIR=partnership-data
ALLOWED_TELEGRAM_IDS=
LEADS_POLL_INTERVAL_SEC=90
