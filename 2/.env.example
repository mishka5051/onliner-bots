# Application
APP_NAME=event-search
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://events:events@localhost:5432/event_search

# Search provider: fake | searxng | serpapi
SEARCH_PROVIDER=searxng

# SearXNG (when SEARCH_PROVIDER=searxng) — поднимается через docker compose
SEARXNG_BASE_URL=http://localhost:8080

# SerpAPI (when SEARCH_PROVIDER=serpapi)
SERPAPI_API_KEY=

# Default number of results per search query
SEARCH_RESULTS_LIMIT=10

# Enrichment and scoring
ENRICHMENT_ENABLED=true
SUPPLEMENTARY_SEARCH_ENABLED=true
SHORTLIST_MIN_SCORE=50
SCORING_RULES_PATH=config/scoring_rules.yaml

# Scheduler (weekly search)
SCHEDULER_ENABLED=false
SCHEDULER_CRON=0 9 * * 1

# Optional LLM analysis (phase 4)
LLM_PROVIDER=none
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
